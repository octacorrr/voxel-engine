import * as THREE from 'three';

export class Controls {
    constructor(camera) {
        this.camera = camera;
        this.moveForward = false;
        
        // Rastreadores de dedos (para no confundir el izquierdo con el derecho)
        this.touchMoveId = null; 
        this.touchSteerId = null; 
        
        this.previousTouch = { x: 0, y: 0 };
        
        this.initMobileControls();
    }

    initMobileControls() {
        // CUANDO TOCAS LA PANTALLA
        document.addEventListener('touchstart', (e) => {
            // Revisamos todos los dedos que acaban de tocar
            for (let i = 0; i < e.changedTouches.length; i++) {
                const touch = e.changedTouches[i];
                
                // Mitad Izquierda: Caminar
                if (touch.pageX < window.innerWidth / 2 && this.touchMoveId === null) {
                    this.touchMoveId = touch.identifier; // Registramos este dedo
                    this.moveForward = true;
                } 
                // Mitad Derecha: Girar
                else if (touch.pageX >= window.innerWidth / 2 && this.touchSteerId === null) {
                    this.touchSteerId = touch.identifier; // Registramos este otro dedo
                    this.previousTouch.x = touch.pageX;
                    this.previousTouch.y = touch.pageY;
                }
            }
        }, { passive: false });

        // CUANDO DESLIZAS EL DEDO
        document.addEventListener('touchmove', (e) => {
            e.preventDefault(); // Evita que la pantalla intente hacer scroll
            
            for (let i = 0; i < e.changedTouches.length; i++) {
                const touch = e.changedTouches[i];
                
                // Solo rotamos la cámara si el dedo que se mueve es el del "Volante" (Derecho)
                if (touch.identifier === this.touchSteerId) {
                    const deltaX = touch.pageX - this.previousTouch.x;
                    const deltaY = touch.pageY - this.previousTouch.y;

                    // Ajusta estos valores (0.005) si la cámara gira muy rápido o muy lento
                    this.camera.rotation.y -= deltaX * 0.005;
                    this.camera.rotation.x -= deltaY * 0.005;

                    this.previousTouch.x = touch.pageX;
                    this.previousTouch.y = touch.pageY;
                }
            }
        }, { passive: false });

        // CUANDO LEVANTAS EL DEDO
        document.addEventListener('touchend', (e) => {
            for (let i = 0; i < e.changedTouches.length; i++) {
                const touch = e.changedTouches[i];
                
                // Si levantamos el dedo izquierdo, nos detenemos
                if (touch.identifier === this.touchMoveId) {
                    this.touchMoveId = null;
                    this.moveForward = false;
                }
                // Si levantamos el dedo derecho, dejamos de registrar el giro
                if (touch.identifier === this.touchSteerId) {
                    this.touchSteerId = null;
                }
            }
        }, { passive: false });
    }

    update(delta) {
        if (this.moveForward) {
            // El '15' es la velocidad a la que camina el personaje
            this.camera.translateZ(-15 * delta); 
        }
    }
}
