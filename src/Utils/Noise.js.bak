// src/Utils/Noise.js

export function getTerrainHeight(x, z) {
    // CAPA 1: Montañas grandes y colinas anchas (Frecuencia baja)
    const scale1 = 0.02;
    const amp1 = 12;
    const layer1 = (Math.sin(x * scale1) + Math.cos(z * scale1)) * amp1;

    // CAPA 2: Detalles del terreno y valles medianos (Frecuencia media)
    const scale2 = 0.08;
    const amp2 = 4;
    const layer2 = (Math.sin(x * scale2) * Math.cos(z * scale2)) * amp2;

    // CAPA 3: Rugosidad y pequeños escalones en el suelo (Frecuencia alta)
    const scale3 = 0.2;
    const amp3 = 1.5;
    const layer3 = (Math.sin(x * scale3) + Math.cos(z * scale3)) * amp3;

    // Sumamos las tres capas para generar un relieve caótico pero natural
    const finalHeight = layer1 + layer2 + layer3;

    // Retornamos la altura con un piso base de 12 bloques para que nunca baje de 0
    return Math.floor(finalHeight + 12); 
}
